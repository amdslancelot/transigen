# Template for deploy/.env.production, the single source of truth for
# deploy/bootstrap.sh. Copy this file to deploy/.env.production and fill
# in real values before running ./deploy/bootstrap.sh. That file is
# gitignored — never commit it.

# --- Supabase (same project as local development) ---

# Supabase project URL. Settings -> API in the Supabase dashboard.
# Baked into the web image at build time (client-visible).
NEXT_PUBLIC_SUPABASE_URL=

# Supabase publishable/anon key. Settings -> API. Baked into the web
# image at build time (client-visible; safe to expose, RLS enforces
# access control).
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Production auth flow. Must be "magic_link" in production. Never set
# this to "dev_email_only" for a deployed environment — that flow
# bypasses email verification and is local/dev only.
NEXT_PUBLIC_AUTH_FLOW=magic_link

# Supabase service role (secret) key. Settings -> API. Used server-side
# only; stored in the web-runtime Kubernetes Secret, never baked into the
# client bundle. Do not confuse with NEXT_PUBLIC_SUPABASE_ANON_KEY above.
SUPABASE_SERVICE_ROLE_KEY=

# --- YouTube Data API ---

# Google Cloud Console -> YouTube Data API v3 -> Credentials. Used
# server-side to auto-fill title/channel/duration when adding songs.
# Optional: the app works without it, just without auto-fill.
YOUTUBE_API_KEY=

# --- OCIR (OCI Container Registry) push credential ---

# Format: <tenancy-namespace>/<username>. The tenancy namespace is shown
# in the OCI Console under Governance & Administration -> Tenancy
# Details. <username> is your OCI IAM username (or, for federated/IDCS
# users, the full federated username as shown in the console).
OCIR_USERNAME=

# An OCI Auth Token generated for this user: Profile -> User Settings ->
# Auth Tokens -> Generate Token, in the OCI Console. This is not your OCI
# account password — Auth Tokens are a separate credential type used for
# registry and API access that does not support the primary sign-in flow.
OCIR_AUTH_TOKEN=

# --- Terraform variables (infra/variables.tf) ---

# OCID of your OCI tenancy. OCI Console -> Profile menu -> Tenancy, or
# `oci iam compartment list --compartment-id-in-subtree false` after
# `oci setup config`.
TF_VAR_tenancy_ocid=

# OCID of the compartment to create resources in. Can be the same as
# TF_VAR_tenancy_ocid if you are not using a dedicated compartment.
TF_VAR_compartment_ocid=

# OCI region identifier (full name only, e.g. us-ashburn-1). Must be a
# region where A1 Flex always-free capacity is available for your
# tenancy. You do not need to supply the short OCIR region key (e.g.
# "iad") anywhere — Terraform derives it automatically from this value
# via the tenancy's region subscriptions.
TF_VAR_region=
