[
  {
    "id": "deploy-transigen",
    "execute-command": "/opt/transigen/deploy/deploy.sh",
    "command-working-directory": "/opt/transigen",
    "response-message": "Transigen deploy triggered.",
    "trigger-rule": {
      "and": [
        {
          "match": {
            "type": "payload-hmac-sha256",
            "secret": "{{WEBHOOK_SECRET}}",
            "parameter": {
              "source": "header",
              "name": "X-Hub-Signature-256"
            }
          }
        },
        {
          "match": {
            "type": "value",
            "value": "refs/heads/main",
            "parameter": {
              "source": "payload",
              "name": "ref"
            }
          }
        }
      ]
    }
  }
]
