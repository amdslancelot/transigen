# Template for the prod transigen-env Secret values. Copy to deploy/env.prod
# on the server (gitignored, chmod 600 — setup-app.sh does this with the DB
# password and AUTH_SECRET filled in), then deploy.sh creates/refreshes the
# Secret from it on every deploy (kubectl create secret --from-env-file).
# Real passwords live only in that gitignored env file; no Secret YAML exists
# anywhere. ${TRANSIGEN_HOST} is substituted by deploy.sh at apply time.

# Shared Postgres in the `data` namespace. The transigen_rw password must match
# the TRANSIGEN_DB_PASSWORD used when provisioning via deploy/provision-db.sh
# (run by deploy/setup-app.sh).
DATABASE_URL=postgres://transigen_rw:replace-with-transigen-db-password@postgres.data.svc.cluster.local:5432/transigen

# Auth.js session/JWT signing secret. Generate with: openssl rand -base64 32
AUTH_SECRET=replace-with-openssl-rand-base64-32

# Google OAuth client used for sign-in. The client must list
# https://${TRANSIGEN_HOST}/api/auth/callback/google as an authorized
# redirect URI.
AUTH_GOOGLE_ID=replace-with-google-oauth-client-id
AUTH_GOOGLE_SECRET=replace-with-google-oauth-client-secret

# Canonical public URL of the deployed app; substituted from $TRANSIGEN_HOST.
AUTH_URL=https://${TRANSIGEN_HOST}
AUTH_TRUST_HOST=true

# Optional integrations; the app works without them.
YOUTUBE_API_KEY=
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
