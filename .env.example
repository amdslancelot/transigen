NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Auth UI: magic_link | email_password | dev_email_only
# Restart dev server after changing.
NEXT_PUBLIC_AUTH_FLOW=magic_link

# --- dev_email_only only (never enable in production) ---
# AUTH_DEV_EMAIL_BYPASS=1
# SUPABASE_SERVICE_ROLE_KEY=
# AUTH_DEV_SHARED_PASSWORD=

# --- YouTube Data API v3 (server-only) ---
# Used to fetch reliable video metadata (title, channel, duration).
# Get one at https://console.cloud.google.com/apis/library/youtube.googleapis.com (free, 10k units/day).
YOUTUBE_API_KEY=

# --- Spotify Web API (server-only, Client Credentials flow) ---
# Used to look up track BPM from a sanitized YouTube title.
# Get credentials at https://developer.spotify.com/dashboard (free).
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
