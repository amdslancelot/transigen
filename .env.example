# PostgreSQL connection string. Dev shares the minikube-hosted Postgres in the
# `data` namespace (same instance staging uses), reached through a port-forward
# tunnel, as the least-privilege transigen_rw role — never the superuser:
#   deploy/stage.sh                                        # once: data plane + provisioning
#   kubectl -n data port-forward svc/postgres 54321:5432   # keep running while developing
DATABASE_URL=postgresql://transigen_rw:transigen@localhost:54321/transigen

# --- Auth.js (Google OAuth) ---
# Session-cookie signing secret. Generate with: openssl rand -base64 32
AUTH_SECRET=
# Google OAuth client: https://console.cloud.google.com/apis/credentials
# -> Create Credentials -> OAuth client ID -> Web application.
# Authorized JavaScript origin:  http://localhost:3000
# Authorized redirect URI:       http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# --- YouTube Data API v3 (server-only, optional) ---
# Used to fetch reliable video metadata (title, channel, duration).
# Get one at https://console.cloud.google.com/apis/library/youtube.googleapis.com (free, 10k units/day).
YOUTUBE_API_KEY=

# --- Spotify Web API (server-only, optional, Client Credentials flow) ---
# Used to look up track BPM from a sanitized YouTube title.
# Get credentials at https://developer.spotify.com/dashboard (free).
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
